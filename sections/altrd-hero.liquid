{%- style -%}
  .altrd-hero-section {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    padding: 0;
    margin-top: 0;
  }

  .altrd-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .altrd-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.80) 0%,
      rgba(0, 0, 0, 0.30) 50%,
      rgba(0, 0, 0, 0.05) 100%
    );
    z-index: 1;
  }

  .altrd-hero-content {
    position: relative;
    z-index: 2;
    padding: 0 60px 80px;
    width: 100%;
    max-width: 900px;
  }

  @media (max-width: 749px) {
    .altrd-hero-content { padding: 0 24px 60px; }
  }
{%- endstyle -%}

<section class="altrd-hero-section shopify-section">
  {%- if section.settings.image != blank -%}
    <img
      class="altrd-hero-bg"
      src="{{ section.settings.image | image_url: width: 2400 }}"
      srcset="
        {{ section.settings.image | image_url: width: 750 }} 750w,
        {{ section.settings.image | image_url: width: 1200 }} 1200w,
        {{ section.settings.image | image_url: width: 1800 }} 1800w,
        {{ section.settings.image | image_url: width: 2400 }} 2400w
      "
      sizes="100vw"
      alt="{{ section.settings.image.alt | default: shop.name | escape }}"
      loading="eager"
      fetchpriority="high"
      width="{{ section.settings.image.width }}"
      height="{{ section.settings.image.height }}"
    >
  {%- else -%}
    <div class="altrd-hero-bg" style="background: #0A0A0A;"></div>
  {%- endif -%}

  <div class="altrd-hero-overlay"></div>

  <div class="altrd-hero-content">
    {%- if section.settings.eyebrow != blank -%}
      <p class="altrd-hero-eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="altrd-hero-headline">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="altrd-hero-sub">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}

    <div class="altrd-hero-cta-group">
      {%- if section.settings.cta_label_1 != blank -%}
        <a
          href="{{ section.settings.cta_link_1 | default: '/collections/all' }}"
          class="altrd-hero-btn-primary"
        >
          {{ section.settings.cta_label_1 | escape }}
        </a>
      {%- endif -%}
      {%- if section.settings.cta_label_2 != blank -%}
        <a
          href="{{ section.settings.cta_link_2 | default: '/collections/all' }}"
          class="altrd-hero-btn-ghost"
        >
          {{ section.settings.cta_label_2 | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Altrd Hero",
  "tag": "section",
  "class": "altrd-hero-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero background image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Altrd Store · SS26"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "WEAR THE SHIFT"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium streetwear. Limited drops. Not for everyone."
    },
    {
      "type": "text",
      "id": "cta_label_1",
      "label": "Primary CTA label",
      "default": "Shop New Drop"
    },
    {
      "type": "url",
      "id": "cta_link_1",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_label_2",
      "label": "Ghost CTA label",
      "default": "View Lookbook"
    },
    {
      "type": "url",
      "id": "cta_link_2",
      "label": "Ghost CTA link"
    }
  ],
  "presets": [
    {
      "name": "Altrd Hero"
    }
  ]
}
{% endschema %}
